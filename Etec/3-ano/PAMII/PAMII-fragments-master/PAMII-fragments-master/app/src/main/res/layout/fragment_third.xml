<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ThirdFragment"
    android:background="#FFD3D3">

    <!-- TODO: Update blank fragment layout -->
    <TextView android:id="@+id/topo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:height="70dp"
        android:text="Terceiro"
        android:textStyle="bold"
        android:textSize="36sp"
        android:gravity="center"
        android:textColor="@color/white"
        android:background="#A21E1E"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView android:id="@+id/texto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Terceira tela Fragments"
        android:textSize="25sp"
        android:textStyle="bold"
        android:layout_marginTop="270dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="1.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topo"/>

</androidx.constraintlayout.widget.ConstraintLayout>